<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Monthly Events - The Wandering Lantern</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --warm-brown: #8b6f47;
            --deep-brown: #5c4d3c;
            --aged-gold: #c9a961;
            --muted-gold: #a38b5f;
            --cream: #faf7f0;
            --parchment: #f5eedc;
            --dark-text: #3a2f27;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: white;
            font-family: 'Libre Baskerville', 'Georgia', serif;
            color: var(--dark-text);
        }

        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background: white !important;
            }
            .print-page {
                max-width: 100% !important;
                margin: 0 !important;
                padding: 6mm !important;
            }
            @page {
                size: letter;
                margin: 6mm;
            }
            .print-header {
                padding-bottom: 0.3rem !important;
                margin-bottom: 0.3rem !important;
                border-bottom-width: 1px !important;
            }
            .month-highlight {
                font-size: 1.3rem !important;
                margin-bottom: 0.15rem !important;
            }
            .print-event {
                padding: 0.25rem 0 !important;
                gap: 0.6rem !important;
            }
            .print-event-date {
                font-size: 0.65rem !important;
                padding: 0.2rem 0.3rem !important;
                width: 55px !important;
                flex: 0 0 55px !important;
            }
            .print-event-title {
                font-size: 0.85rem !important;
            }
            .print-event-meta {
                font-size: 0.65rem !important;
            }
            .print-event-excerpt {
                font-size: 0.6rem !important;
                line-height: 1.25 !important;
            }
            .print-event-price {
                font-size: 0.65rem !important;
                padding: 0.05rem 0.3rem !important;
            }
            .print-footer {
                margin-top: 0.5rem !important;
                padding-top: 0.5rem !important;
            }
            .print-footer .footer-branding h2 {
                font-size: 1.1rem !important;
            }
            .print-footer .tagline {
                font-size: 0.75rem !important;
            }
            .print-footer .footer-info {
                font-size: 0.7rem !important;
            }
            .qr-compact img {
                width: 55px !important;
                height: 55px !important;
            }
            .qr-label {
                font-size: 0.7rem !important;
            }
        }

        .print-page {
            max-width: 8.5in;
            margin: 0 auto;
            padding: 0.5in;
            background: white;
        }

        .print-header {
            text-align: center;
            padding-bottom: 0.75rem;
            margin-bottom: 1rem;
            border-bottom: 2px solid var(--aged-gold);
        }

        .month-highlight {
            color: var(--deep-brown);
            display: inline-block;
            padding: 0;
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 0.25rem;
        }

        #events-container {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .print-event {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.5rem 0;
            border-bottom: 1px solid #e0d5c0;
        }

        .print-event:last-child {
            border-bottom: none;
        }

        .print-event-date {
            font-family: 'Playfair Display', serif;
            color: white;
            background: var(--deep-brown);
            padding: 0.3rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: bold;
            white-space: nowrap;
            width: 65px;
            text-align: center;
            flex: 0 0 65px;
        }

        .print-event-details {
            flex: 1 1 auto;
        }

        .print-event-title-row {
            display: flex;
            align-items: baseline;
            gap: 0.5rem;
        }

        .print-event-title {
            font-family: 'Playfair Display', serif;
            color: var(--deep-brown);
            font-size: 1.05rem;
            margin: 0;
            font-weight: bold;
        }

        .print-event-price {
            font-size: 0.8rem;
            font-weight: bold;
            color: var(--warm-brown);
            background: var(--cream);
            padding: 0.1rem 0.4rem;
            border-radius: 3px;
            border: 1px solid var(--aged-gold);
            white-space: nowrap;
            flex-shrink: 0;
        }

        .print-event-meta {
            color: var(--warm-brown);
            font-size: 0.8rem;
            margin-top: 0.1rem;
        }

        .print-event-meta span + span::before {
            content: " · ";
            color: var(--aged-gold);
        }

        .print-event-excerpt {
            color: #6b5d4f;
            font-size: 0.75rem;
            line-height: 1.35;
            margin-top: 0.15rem;
        }

        .print-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 2px solid var(--aged-gold);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .footer-left {
            flex: 1;
        }

        .footer-branding h2 {
            font-family: 'Playfair Display', serif;
            color: var(--deep-brown);
            font-size: 1.4rem;
            margin-bottom: 0.15rem;
        }

        .footer-branding .tagline {
            color: var(--warm-brown);
            font-style: italic;
            font-size: 0.85rem;
            margin-bottom: 0.35rem;
        }

        .footer-info {
            color: var(--dark-text);
            font-size: 0.8rem;
            line-height: 1.5;
        }

        .footer-right {
            flex-shrink: 0;
        }

        .qr-compact {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .qr-compact img {
            width: 80px;
            height: 80px;
            border: 2px solid var(--aged-gold);
            padding: 0.25rem;
            background: white;
        }

        .qr-label {
            font-family: 'Playfair Display', serif;
            font-size: 0.8rem;
            color: var(--deep-brown);
            font-weight: bold;
            line-height: 1.3;
        }

        .no-events-message {
            text-align: center;
            padding: 3rem;
            color: var(--warm-brown);
            font-style: italic;
            font-size: 1.1rem;
        }

        .print-button {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--aged-gold);
            color: white;
            border: none;
            padding: 1rem 2rem;
            font-size: 1rem;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Playfair Display', serif;
            font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            z-index: 1000;
        }

        .print-button:hover {
            background: var(--warm-brown);
        }

        .hidden {
            display: none;
        }

        .month-picker {
            position: fixed;
            top: 20px;
            left: 20px;
            background: white;
            border: 2px solid var(--aged-gold);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-family: 'Playfair Display', serif;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            z-index: 1000;
        }

        .month-picker label {
            color: var(--deep-brown);
            font-size: 0.9rem;
            font-weight: bold;
        }

        .month-picker select {
            font-family: 'Playfair Display', serif;
            font-size: 0.9rem;
            padding: 0.25rem 0.5rem;
            border: 1px solid var(--aged-gold);
            border-radius: 4px;
            color: var(--dark-text);
            background: var(--cream);
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="month-picker no-print">
        <label for="month-select">Month:</label>
        <select id="month-select">
            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>
        </select>
        <select id="year-select"></select>
    </div>

    <button class="print-button no-print" onclick="scaleAndPrint()">🖨️ Print This Page</button>

    <div class="print-page">
        <div class="print-header">
            <div class="month-highlight" id="current-month"></div>
        </div>

        <div id="events-container">
            {% for event in collections.all %}
                {% if event.inputPath.includes('/events/') and event.inputPath.endsWith('.md') %}
                <div class="print-event" data-event-date="{{ event.data.date | date('YYYY-MM-DD') }}">
                    <div class="print-event-date">{{ event.data.date | date('MMM') }} {{ event.data.date | date('D') }}</div>
                    <div class="print-event-details">
                        <div class="print-event-title-row">
                            <span class="print-event-title">{{ event.data.title }}</span>
                            {% if event.data.price %}<span class="print-event-price">{{ event.data.price }}</span>{% endif %}
                        </div>
                        <div class="print-event-meta">
                            {% if event.data.time %}<span>{{ event.data.time }}</span>{% endif %}
                            {% if event.data.ageRange %}<span>Ages {{ event.data.ageRange }}</span>{% endif %}
                        </div>
                        {% if event.data.excerpt %}<div class="print-event-excerpt">{{ event.data.excerpt }}</div>{% endif %}
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </div>

        <div id="no-events-message" class="no-events-message hidden">
            No events scheduled for this month. Check back soon for upcoming events!
        </div>

        <div class="print-footer">
            <div class="footer-left">
                <div class="footer-branding">
                    <h2>The Wandering Lantern</h2>
                    <div class="tagline">"Follow the light, find the wonder"</div>
                </div>
                <div class="footer-info">
                    15729 Madison Ave, Lakewood, OH 44107 · (216) 999-4462<br>
                    @thewanderinglanterncle
                </div>
            </div>
            <div class="footer-right">
                <div class="qr-compact">
                    <img src="/assets/images/qrcode_thewanderinglantern_events.png" alt="Events QR">
                    <div class="qr-label">Scan for events<br>& registration</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Populate year dropdown
        const yearSelect = document.getElementById('year-select');
        [2025, 2026, 2027].forEach(y => {
            const opt = document.createElement('option');
            opt.value = y;
            opt.textContent = y;
            yearSelect.appendChild(opt);
        });

        // Default to current month/year
        const monthSelect = document.getElementById('month-select');
        const today = new Date();
        monthSelect.value = today.getMonth() + 1;
        yearSelect.value = today.getFullYear();

        function filterEvents() {
            const targetMonth = parseInt(monthSelect.value); // 1-12
            const targetYear = parseInt(yearSelect.value);

            const monthYear = new Date(targetYear, targetMonth - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
            document.getElementById('current-month').textContent = monthYear;

            const eventElements = document.querySelectorAll('.print-event');
            let visibleCount = 0;

            eventElements.forEach((eventEl) => {
                const dateStr = eventEl.getAttribute('data-event-date');
                if (!dateStr) { eventEl.style.display = 'none'; return; }
                const parts = dateStr.split('-');
                const eventYear = parseInt(parts[0]);
                const eventMonth = parseInt(parts[1]);
                if (eventMonth === targetMonth && eventYear === targetYear) {
                    eventEl.style.display = 'flex';
                    visibleCount++;
                } else {
                    eventEl.style.display = 'none';
                }
            });

            const noEventsMsg = document.getElementById('no-events-message');
            noEventsMsg.classList.toggle('hidden', visibleCount > 0);
        }

        monthSelect.addEventListener('change', filterEvents);
        yearSelect.addEventListener('change', filterEvents);

        // Scale content to fit one printed page
        function scaleAndPrint() {
            const page = document.querySelector('.print-page');
            // Letter page: 11in minus 12mm margins ≈ 10.06in = 965px
            const maxHeight = 10.06 * 96;
            const contentHeight = page.scrollHeight;
            if (contentHeight > maxHeight) {
                const scale = Math.floor((maxHeight / contentHeight) * 1000) / 1000;
                page.style.transform = `scale(${scale})`;
                page.style.transformOrigin = 'top left';
                page.style.width = `${100 / scale}%`;
            }
            setTimeout(() => {
                window.print();
                // Reset after print
                page.style.transform = '';
                page.style.transformOrigin = '';
                page.style.width = '';
            }, 100);
        }

        // Run on load
        filterEvents();
    </script>
</body>
</html>
