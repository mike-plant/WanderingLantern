---
layout: layouts/base.njk
---

{% if not recurring %}
<script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": {{ title | dump | safe }},
  "description": {{ excerpt | dump | safe }},
  "startDate": "{{ date | eventStartISO(time) }}",
  "endDate": "{{ date | eventEndISO(time) }}",
  "eventStatus": "{% if status == 'cancelled' %}https://schema.org/EventCancelled{% else %}https://schema.org/EventScheduled{% endif %}",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {% if location %}{
    "@type": "Place",
    "name": {{ location | dump | safe }}
  }{% else %}{
    "@type": "Place",
    "name": "The Wandering Lantern",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "15729 Madison Ave",
      "addressLocality": "Lakewood",
      "addressRegion": "OH",
      "postalCode": "44107",
      "addressCountry": "US"
    }
  }{% endif %},
  "organizer": {
    "@type": "Organization",
    "name": "The Wandering Lantern",
    "url": "https://thewanderinglantern.com"
  },
  "url": "https://thewanderinglantern.com{{ page.url }}"{% if price %},
  "offers": {
    "@type": "Offer",
    "name": {{ price | dump | safe }},
    "url": "https://thewanderinglantern.com{{ page.url }}"
  }{% endif %}
}</script>
{% endif %}

{# Event detail page layout #}
<div class="event-hero" style="background: linear-gradient(135deg, rgba(122, 139, 111, 0.12) 0%, rgba(139, 111, 71, 0.12) 100%); padding: 3rem 2rem; text-align: center; border-bottom: 2px solid rgba(201, 169, 97, 0.3);">
    <div class="container">
        {% if features.events.enableEventFlyers and flyerImage %}
        <div style="max-width: 600px; margin: 0 auto 2rem;">
            <img src="{{ flyerImage }}" alt="{{ title }}" style="width: 100%; height: auto; border-radius: 8px; box-shadow: 0 8px 24px rgba(90, 75, 60, 0.2);">
        </div>
        {% endif %}

        <h1 style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3.5rem); color: var(--deep-brown); margin-bottom: 0.5rem;">{{ title }}</h1>

        {% if host %}
        <p style="font-size: 1rem; color: var(--muted-gold); margin-bottom: 0.5rem; font-style: italic;">Presented with {{ host }}</p>
        {% endif %}

        <div class="event-meta" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem; font-size: 1.1rem; color: var(--warm-brown); margin-top: 1.5rem;">
            {% if recurring and recurringSchedule %}
            <div>
                <strong>Schedule:</strong> {{ recurringSchedule }}
            </div>
            {% elif dateRange %}
            <div>
                <strong>Dates:</strong> {{ dateRange }}
            </div>
            {% elif date %}
            <div>
                <strong>Date:</strong> {{ date | date('dddd') }}, {{ date | date('MMMM D, YYYY') }}
            </div>
            {% endif %}

            {% if time %}
            <div>
                <strong>Time:</strong> {{ time }}
            </div>
            {% endif %}

            {% if ageRange %}
            <div>
                <strong>Ages:</strong> {{ ageRange }}
            </div>
            {% endif %}

            {% if price %}
            <div>
                <strong>Price:</strong> {{ price }}
            </div>
            {% endif %}

            {% if location %}
            <div>
                📍 {{ location }}
            </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="container">
    <div class="event-content" style="max-width: 800px; margin: 3rem auto;">
        {{ content | safe }}
    </div>

    {# Cancelled notice — shown instead of registration #}
    {% if status == 'cancelled' %}
    <div style="max-width: 600px; margin: 2rem auto; padding: 2rem; background: rgba(180, 60, 60, 0.07); border: 2px solid #b43c3c; border-radius: 8px; text-align: center;">
        <p style="font-size: 1.2rem; color: #b43c3c; font-weight: bold; margin: 0 0 0.5rem;">This event has been cancelled.</p>
        <p style="font-size: 1rem; color: var(--deep-brown); margin: 0;">We're sorry for the inconvenience. Check back for future events!</p>
    </div>
    {# Shopify ticket link #}
    {% elif ticketUrl and (recurring or not isPastEvent(date, time)) %}
    <div style="max-width: 600px; margin: 2rem auto; padding: 2rem; background: rgba(139, 111, 71, 0.08); border: 2px solid var(--aged-gold); border-radius: 8px; text-align: center;">
        <p style="font-size: 1.1rem; color: var(--deep-brown); margin-bottom: 1.5rem;"><strong>Secure your spot before time runs out!</strong></p>
        <a href="{{ ticketUrl }}" target="_blank" rel="noopener noreferrer" class="cta-button" style="display: inline-block; padding: 1rem 2.5rem; font-size: 1.1rem; text-decoration: none;">Purchase Tickets</a>
    </div>
    {# Include Mailchimp registration form if form details are provided and event is in the future #}
    {% elif mailchimpFormId and mailchimpTag and (recurring or not isPastEvent(date, time)) %}
    {% include "components/mailchimp-event-form.njk" %}
    {# External registration URL — only shown when no Mailchimp form is configured #}
    {% elif registrationUrl and (recurring or not isPastEvent(date, time)) %}
    <div style="max-width: 600px; margin: 2rem auto; padding: 2rem; background: rgba(139, 111, 71, 0.08); border: 2px solid var(--aged-gold); border-radius: 8px; text-align: center;">
        <a href="{{ registrationUrl }}" target="_blank" rel="noopener noreferrer" class="cta-button" style="display: inline-block; padding: 1rem 2.5rem; font-size: 1.1rem; text-decoration: none;">Register here →</a>
    </div>
    {% elif not recurring and isPastEvent(date, time) %}
    <div style="max-width: 600px; margin: 2rem auto; padding: 2rem; background: rgba(139, 111, 71, 0.08); border: 2px solid var(--aged-gold); border-radius: 8px; text-align: center;">
        <p style="font-size: 1.1rem; color: var(--deep-brown); margin: 0;"><strong>Registration is now closed.</strong></p>
    </div>
    {% endif %}
</div>
