{# Event card component for use in event listings #}
{# Usage: {% include "components/event-card.njk" %} #}

<a href="{{ event.url }}" class="event-card-link">
    <div class="event-card {% if isPastEvent(event.data.date, event.data.time) %}event-card--closed{% elif event.data.status %}event-card--{{ event.data.status }}{% endif %}">
        {% if isPastEvent(event.data.date, event.data.time) %}
        <div class="event-status-badge event-status-badge--closed">
            CLOSED
        </div>
        {% elif event.data.status %}
        <div class="event-status-badge event-status-badge--{{ event.data.status }}">
            {% if event.data.status == 'cancelled' %}CANCELLED
            {% elif event.data.status == 'full' %}FULL
            {% endif %}
        </div>
        {% endif %}

        {# Date block — shown in list view on the left, hidden in grid view #}
        {% if event.data.date %}
        <div class="event-card-date-block" aria-hidden="true">
            <span class="event-card-date-month">{{ event.data.date | date('MMM') }}</span>
            <span class="event-card-date-day">{{ event.data.date | date('D') }}</span>
        </div>
        {% endif %}

        <div class="event-card-content">
            {% if event.data.category %}
            <span class="event-category-badge event-category-badge--{{ event.data.category }}">
                {%- if event.data.category == 'author-visit' -%}Author Visit
                {%- elif event.data.category == 'workshop' -%}Workshop
                {%- elif event.data.category == 'story-time' -%}Story Time
                {%- elif event.data.category == 'special-event' -%}Special Event
                {%- else -%}{{ event.data.category }}{%- endif -%}
            </span>
            {% endif %}
            <h3 class="event-card-title">{{ event.data.title }}</h3>
            <div class="event-card-meta">
                {% if event.data.date %}
                <div class="event-meta-date"><strong>{{ event.data.date | date('MMMM D, YYYY') }}</strong></div>
                {% endif %}
                {% if event.data.time %}
                <div class="event-meta-time">{{ event.data.time }}</div>
                {% endif %}
            </div>
            <p class="event-card-description">{{ event.data.excerpt }}</p>
            {% if event.data.ageRange %}
            <span class="event-badge">Ages {{ event.data.ageRange }}</span>
            {% endif %}
            <div class="event-card-cta">
                Learn More & RSVP →
            </div>
        </div>
    </div>
</a>
